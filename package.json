{
    "name": "inclusive-shortcuts",
    "version": "0.1.0",
    "description": "Accessible, DOM-driven keyboard shortcuts for web apps.",
    "type": "module",
    "main": "./dist/index.js",
    "module": "dist/index.js",
    "types": "dist/types/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/types/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        },
        "./package.json": "./package.json"
    },
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/tobyzerner/inclusive-shortcuts.git"
    },
    "homepage": "https://github.com/tobyzerner/inclusive-shortcuts#readme",
    "bugs": {
        "url": "https://github.com/tobyzerner/inclusive-shortcuts/issues"
    },
    "files": [
        "dist"
    ],
    "sideEffects": false,
    "scripts": {
        "dev": "vite",
        "build": "tsc --noEmit && vite build && tsc --emitDeclarationOnly",
        "lint": "eslint .",
        "prepare": "pnpm build",
        "preview": "vite preview",
        "test": "vitest run",
        "release": "release-it"
    },
    "dependencies": {
        "tinykeys": "^3.0.0"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.4",
        "@release-it/conventional-changelog": "^5.1.1",
        "@typescript-eslint/eslint-plugin": "^8.57.1",
        "@typescript-eslint/parser": "^8.57.1",
        "eslint": "^9.39.4",
        "jsdom": "^29.0.1",
        "prettier": "^2.8.8",
        "release-it": "^15.11.0",
        "typescript": "^5.9.3",
        "vite": "^8.0.1",
        "vitest": "^4.1.0"
    },
    "release-it": {
        "git": {
            "commitMessage": "release: v${version}",
            "tagName": "v${version}"
        },
        "github": {
            "release": true,
            "releaseName": "v${version}"
        },
        "plugins": {
            "@release-it/conventional-changelog": {
                "preset": "conventionalcommits",
                "infile": "CHANGELOG.md",
                "header": "# Changelog"
            }
        },
        "hooks": {
            "after:bump": "npm run build"
        }
    },
    "prettier": {
        "singleQuote": true
    },
    "packageManager": "pnpm@10.17.1+sha512.17c560fca4867ae9473a3899ad84a88334914f379be46d455cbf92e5cf4b39d34985d452d2583baf19967fa76cb5c17bc9e245529d0b98745721aa7200ecaf7a"
}
